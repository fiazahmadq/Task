# Database
MONGODB_URI=mongodb://localhost:27017/nexusai
REDIS_URL=redis://localhost:6379

# Auth
AUTH_SECRET=change-me-to-a-32-char-random-string
NEXTAUTH_URL=http://localhost:3000

# AI Providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_AI_API_KEY=...

# CORS
NEXT_PUBLIC_ALLOWED_ORIGINS=http://localhost:3000

# Feature flags
NEXT_PUBLIC_ENABLE_VOICE=true
NEXT_PUBLIC_ENABLE_COMPARISON=true

# Monitoring
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Logging
LOG_LEVEL=info

# Storage (file uploads)
S3_BUCKET=nexusai-uploads
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
